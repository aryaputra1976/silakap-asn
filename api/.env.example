APP_NAME=SILAKAP API
APP_ENV=production
APP_PORT=3000
APP_URL=https://api.silakap.go.id
APP_TRUST_PROXY=1
ENABLE_SWAGGER=false
FORCE_HTTPS=true

DATABASE_URL=mysql://user:password@db-host:3306/silakap

JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m

REDIS_ENABLED=true
REDIS_HOST=redis-host
REDIS_PORT=6379
REDIS_PASSWORD=change-me

MINIO_ENDPOINT=minio-host
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=silakap-docs

SINGLE_TENANT=true
DEFAULT_TENANT=bone

CORS_ORIGIN=https://silakap.bkpsdm-tolis.or.id

COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
