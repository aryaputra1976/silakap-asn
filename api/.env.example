APP_NAME=SILAKAP API
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
APP_TRUST_PROXY=1
ENABLE_SWAGGER=true
FORCE_HTTPS=false

DATABASE_URL=mysql://root:@localhost:3306/silakap

JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m

REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=silakap-docs

SINGLE_TENANT=true
DEFAULT_TENANT=bone

CORS_ORIGIN=http://localhost:5173

COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
