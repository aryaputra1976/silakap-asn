  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  createdBy BigInt? @map("created_by")
  updatedBy BigInt? @map("updated_by")

  pegawai SilakapPegawai[]
  jabatan RefJabatan[]

  riwayatJabatan SilakapRiwayatJabatan[]

  @@index([nama])
  @@index([isActive])
  @@index([deletedAt])
  @@map("ref_jenis_jabatan")
}

model RefJabatan {
  id BigInt @id @default(autoincrement()) @map("id")

  idSiasn String @unique @map("id_siasn") @db.VarChar(100)
  kode    String @unique @map("kode") @db.VarChar(100)
  nama    String @map("nama") @db.VarChar(250)

  // === Relasi Jenis Jabatan ===
  jenisJabatanId BigInt?          @map("jenis_jabatan_id")
  jenisJabatan   RefJenisJabatan? @relation(fields: [jenisJabatanId], references: [id])

  // ===== STRUKTURAL =====
  eselonId String? @map("eselon_id") @db.VarChar(50)

  // ===== FUNGSIONAL =====
  jenjang String? @map("jenjang") @db.VarChar(100)
  bup     Int?    @map("bup")

  // ===== OPSIONAL UNOR =====
  unorNama String? @map("unor_nama") @db.VarChar(250)

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  pegawai        SilakapPegawai[]
  riwayatJabatan SilakapRiwayatJabatan[]

  // =========================
  // ANJAB RELATIONS
  // =========================
  anjab               RefJabatanAnjab[]
  abkBebanKerja       AbkBebanKerja[]
  abkHasilPerhitungan AbkHasilPerhitungan[]
  workforceFormasi    WorkforceFormasi[]

  @@index([jenisJabatanId])
  @@index([nama])
  @@map("ref_jabatan")
}

model RefInstansi {
  id BigInt @id @default(autoincrement()) @map("id")

  idSiasn String @unique @map("id_siasn") @db.VarChar(100)
  kode    String @unique @map("kode") @db.VarChar(100)
