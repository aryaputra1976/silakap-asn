  deletedAt DateTime? @map("deleted_at")

  createdBy BigInt? @map("created_by")
  updatedBy BigInt? @map("updated_by")

  pegawaiInduk SilakapPegawai[] @relation("instansi_induk")
  pegawaiKerja SilakapPegawai[] @relation("instansi_kerja")

  riwayatJabatan SilakapRiwayatJabatan[]

  @@index([nama])
  @@index([isActive])
  @@index([deletedAt])
  @@map("ref_instansi")
}

model RefSatker {
