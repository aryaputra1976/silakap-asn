datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ======================================================
// ENUM
// ======================================================

enum LayananStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  RETURNED
  APPROVED
  REJECTED
  SYNCED_SIASN
  FAILED_SIASN
}

enum DependencyStatus {
  PENDING
  COMPLETED
}

enum DisposisiStatus {
  SENT
  ACCEPTED
  DONE
}

enum SiasnJobStatus {
  QUEUED
  SUCCESS
  FAILED
}

enum RegistrasiStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DmsImportStatus {
  DRAFT
  IMPORTED
  PARTIAL
  FAILED
}

// ======================================================
// PEREMAJAAN
// ======================================================

model SilakapPeremajaan {
  id        BigInt @id @default(autoincrement()) @map("id")
  layananId BigInt @unique @map("layanan_id")

  layanan SilakapUsulLayanan @relation(fields: [layananId], references: [id])

  jenisPerubahan String  @map("jenis_perubahan")
  keterangan     String? @map("keterangan")
  dataLama       Json?   @map("data_lama")
  dataBaru       Json?   @map("data_baru")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("silakap_peremajaan")
}

// ======================================================
// RBAC
// ======================================================

model SilakapUser {
  id        BigInt  @id @default(autoincrement()) @map("id")
  username  String  @unique @map("username")
  password  String  @map("password")
  pegawaiId BigInt? @unique @map("pegawai_id")
  isActive  Boolean @default(true) @map("is_active")

  pegawai SilakapPegawai? @relation(fields: [pegawaiId], references: [id])

  roles         SilakapUserRole[]
  notifications SilakapNotification[]
  activities    SilakapActivity[]
  auditLogs     AuditLog[]
  authSession   AuthSession[]
  reviewedRegistrations SilakapRegistrasiUser[] @relation("RegistrationReviewer")
  dmsImportedBatches     SilakapDmsBatch[]      @relation("DmsImportedByUser")

  @@map("silakap_user")
}

model SilakapRole {
  id   BigInt @id @default(autoincrement()) @map("id")
  name String @unique @map("name")

  users       SilakapUserRole[]
  permissions SilakapRolePermission[]
  bidang      SilakapBidang[]
  layananLog  SilakapLayananLog[]
  registrations SilakapRegistrasiUser[] @relation("RequestedRegistrationRole")

  @@map("silakap_role")
}

model SilakapPermission {
  id        BigInt    @id @default(autoincrement()) @map("id")
  code      String    @unique @map("code")
  name      String    @map("name")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  rolePermissions SilakapRolePermission[]

  @@map("silakap_permission")
}

model SilakapUserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  user SilakapUser @relation(fields: [userId], references: [id])
  role SilakapRole @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("silakap_user_role")
}

model SilakapRolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  role       SilakapRole       @relation(fields: [roleId], references: [id])
  permission SilakapPermission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("silakap_role_permission")
}

// ======================================================
// ================= REF MASTER (FINAL) =================
// ======================================================

model RefAgama {
  id BigInt @id @default(autoincrement()) @map("id")

  idSiasn String @unique @map("id_siasn") @db.VarChar(100)
  kode    String @unique @map("kode") @db.VarChar(2)
  nama    String @map("nama") @db.VarChar(100)

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  createdBy BigInt? @map("created_by")
  updatedBy BigInt? @map("updated_by")

  pegawai SilakapPegawai[]

  @@index([nama])
  @@index([isActive])
  @@index([deletedAt])
  @@map("ref_agama")
}

model RefAlasanPensiun {
  id BigInt @id @default(autoincrement()) @map("id")

  idSiasn String @unique @map("id_siasn") @db.VarChar(100)
  kode    String @unique @map("kode") @db.VarChar(2)
  nama    String @map("nama") @db.VarChar(100)

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  createdBy BigInt? @map("created_by")
  updatedBy BigInt? @map("updated_by")

  @@index([nama])
  @@index([isActive])
  @@index([deletedAt])
  @@map("ref_alasan_pensiun")
}

model RefGolongan {
  id BigInt @id @default(autoincrement()) @map("id")

  idSiasn String @unique @map("id_siasn") @db.VarChar(100)
  kode    String @unique @map("kode") @db.VarChar(6)
  nama    String @map("nama") @db.VarChar(100)

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  createdBy BigInt? @map("created_by")
  updatedBy BigInt? @map("updated_by")

  pegawaiGolonganAktif SilakapPegawai[] @relation("GolonganAktif")
  pegawaiGolonganAwal  SilakapPegawai[] @relation("GolonganAwal")

  riwayatPangkat SilakapRiwayatPangkat[]
  RefGajiPokok   RefGajiPokok[]

  @@index([nama])
  @@index([isActive])
  @@index([deletedAt])
  @@map("ref_golongan")
}

